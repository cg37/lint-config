{
    "name": "@craig37/lint-config",
    "version": "1.0.21",
    "description": "Shared ESLint + Prettier + commitlint + lint-staged config for TypeScript / React / Vue projects",
    "type": "module",
    "exports": {
        "./eslint": {
            "types": "./dist/src/eslint.config.d.ts",
            "default": "./dist/src/eslint.config.js"
        },
        "./eslint-react": {
            "types": "./dist/src/eslint.react.config.d.ts",
            "default": "./dist/src/eslint.react.config.js"
        },
        "./eslint-vue": {
            "types": "./dist/src/eslint.vue.config.d.ts",
            "default": "./dist/src/eslint.vue.config.js"
        },
        "./prettier": {
            "types": "./dist/src/prettier-config.d.ts",
            "import": "./dist/src/prettier-config.js",
            "require": "./dist/src/prettier-config.cjs",
            "default": "./dist/src/prettier-config.js"
        },
        "./commitlint": {
            "types": "./dist/src/commitlint.config.d.ts",
            "default": "./dist/src/commitlint.config.js"
        }
    },
    "bin": {
        "@craig37/lint-config-setup": "./bin/setup.mjs"
    },
    "files": [
        "dist/",
        "bin/"
    ],
    "scripts": {
        "build": "./node_modules/.bin/tsc && node scripts/build-post.mjs",
        "prepublishOnly": "npm run build",
        "format": "./node_modules/.bin/prettier --write \"**/*.{ts,js,mjs,cjs,json,md}\"",
        "format:check": "./node_modules/.bin/prettier --check \"**/*.{ts,js,mjs,cjs,json,md}\"",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,js,mjs,cjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": [
            "prettier --write"
        ]
    },
    "keywords": [
        "eslint-config",
        "prettier-config",
        "commitlint-config",
        "vue",
        "react",
        "typescript"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cg37/lint-config.git"
    },
    "bugs": {
        "url": "https://github.com/cg37/lint-config/issues"
    },
    "homepage": "https://github.com/cg37/lint-config#readme",
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "@commitlint/cli": ">=19.0.0",
        "@eslint/js": ">=9.0.0",
        "eslint": ">=9.0.0",
        "eslint-config-prettier": ">=10.0.0",
        "eslint-plugin-prettier": ">=5.0.0",
        "eslint-plugin-react": ">=7.0.0",
        "eslint-plugin-react-hooks": ">=5.0.0",
        "eslint-plugin-react-refresh": ">=0.4.0",
        "eslint-plugin-vue": ">=10.0.0",
        "globals": ">=16.0.0",
        "prettier": ">=3.0.0",
        "typescript-eslint": ">=8.0.0",
        "vue-eslint-parser": ">=10.0.0"
    },
    "peerDependenciesMeta": {
        "@commitlint/cli": {
            "optional": true
        },
        "eslint-plugin-react": {
            "optional": true
        },
        "eslint-plugin-react-hooks": {
            "optional": true
        },
        "eslint-plugin-react-refresh": {
            "optional": true
        },
        "eslint-plugin-vue": {
            "optional": true
        },
        "vue-eslint-parser": {
            "optional": true
        }
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/types": "^20.5.0",
        "@eslint/js": "^9.27.0",
        "eslint": "^9.27.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-plugin-prettier": "^5.4.0",
        "eslint-plugin-react": "^7.37.0",
        "eslint-plugin-react-hooks": "^5.1.0",
        "eslint-plugin-react-refresh": "^0.4.18",
        "eslint-plugin-vue": "^10.1.0",
        "globals": "^16.2.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.32.1",
        "vue-eslint-parser": "^10.1.3"
    }
}
